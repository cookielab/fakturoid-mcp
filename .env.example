# Fakturoid OAuth Credentials
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret

# Fakturoid API URL
API_URL=https://app.fakturoid.cz/api/v3

# MCP Transport type (stdio, sse, or http)
MCP_TRANSPORT=stdio

# Attachment Upload Configuration
# Enable/disable URL-based attachment downloads (default: true)
ALLOW_URL_DOWNLOADS=true
# Maximum file size for URL downloads in MB (default: 10)
MAX_DOWNLOAD_SIZE_MB=10
# Download timeout in milliseconds (default: 30000)
DOWNLOAD_TIMEOUT_MS=30000
